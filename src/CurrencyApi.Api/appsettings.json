{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} CorrelationId={CorrelationId} TraceId={TraceId}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Application": "CurrencyApi"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "CurrencyApi",
    "Audience": "CurrencyApiClients",
    "SigningKey": "<INJECT_VIA_ENV_VARS>",
    "ExpiryMinutes": 60
  },
  "Authentication": {
    "Users": [
      {
        "Username": "viewer",
        "Password": "viewer-pass",
        "Role": "User",
        "ClientId": "viewer-client"
      },
      {
        "Username": "admin",
        "Password": "admin-pass",
        "Role": "Admin",
        "ClientId": "admin-client"
      }
    ]
  },
  "Frankfurter": {
    "BaseUrl": "https://api.frankfurter.app/",
    "Resilience": {
      "TimeoutMilliseconds": 3000,
      "MaxRetryAttempts": 2,
      "BaseDelayMilliseconds": 200,
      "CircuitBreakerFailureThreshold": 3,
      "CircuitBreakerBreakSeconds": 30
    }
  },
  "Cache": {
    "LatestTtlSeconds": 30,
    "HistoricalTtlSeconds": 300
  },
  "RateLimiting": {
    "Login": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Historical": {
      "PermitLimit": 3,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  }
}
